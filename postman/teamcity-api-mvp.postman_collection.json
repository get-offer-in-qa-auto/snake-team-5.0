                  "pm.collectionVariables.set('server_build_number', data.buildNumber || ''); try { pm.environment.set('server_build_number', data.buildNumber || ''); } catch (e) {}",
                  "pm.test('server version is present', function () { pm.expect(data.version).to.exist; });"
