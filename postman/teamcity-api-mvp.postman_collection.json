    {
      "name": "Chain D - Failed build lifecycle",
      "item": [
        {
          "name": "D1 Add failing Command Line step",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('failing step added', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const step = pm.response.json();",
                  "if (step.id) { pm.collectionVariables.set('failing_step_id', step.id); try { pm.environment.set('failing_step_id', step.id); } catch (e) {} }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"id\":\"{{failing_step_id}}\",\"name\":\"Autotest failing command line step\",\"type\":\"simpleRunner\",\"properties\":{\"property\":[{\"name\":\"script.content\",\"value\":\"exit 1\"}]}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/app/rest/buildTypes/id:{{build_type_id}}/steps?fields=id,name,type,properties(property(name,value))"
          }
        },
        {
          "name": "D2 Queue failed build",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('failed build queued', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const build = pm.response.json();",
                  "if (build.id) { pm.collectionVariables.set('failed_build_id', String(build.id)); try { pm.environment.set('failed_build_id', String(build.id)); } catch (e) {} }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"buildType\":{\"id\":\"{{build_type_id}}\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/app/rest/buildQueue"
          }
        },
        {
          "name": "D3 Poll failed build result",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const build = pm.response.json();",
                  "const state = String(build.state || '').toLowerCase();",
                  "const pollCount = parseInt((pm.collectionVariables.get('failed_build_poll_count') || pm.environment.get('failed_build_poll_count')) || '0', 10);",
                  "const pollMax = parseInt((pm.collectionVariables.get('build_poll_max') || pm.environment.get('build_poll_max')) || '20', 10);",
                  "if (state !== 'finished' && pollCount < pollMax) {",
                  "  pm.collectionVariables.set('failed_build_poll_count', String(pollCount + 1)); try { pm.environment.set('failed_build_poll_count', String(pollCount + 1)); } catch (e) {}",
                  "  postman.setNextRequest(pm.info.requestName);",
                  "} else {",
                  "  pm.collectionVariables.unset('failed_build_poll_count'); try { pm.environment.unset('failed_build_poll_count'); } catch (e) {}",
                  "  pm.test('failed build finished', function () { pm.expect(state).to.eql('finished'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/app/rest/builds/id:{{failed_build_id}}?fields=id,state,status,statusText,problemOccurrences,webUrl"
          }
        },
        {
          "name": "D4 Check failed build status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status endpoint returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('build status is FAILURE', function () { pm.expect(pm.response.text()).to.eql('FAILURE'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "text/plain"
              }
            ],
            "url": "{{base_url}}/app/rest/builds/id:{{failed_build_id}}/status"
          }
        }
      ]
    },
