          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const build = pm.response.json();",
                  "const state = String(build.state || '').toLowerCase();",
                  "const pollCount = parseInt((pm.collectionVariables.get('build_poll_count') || pm.environment.get('build_poll_count')) || '0', 10);",
                  "const pollMax = parseInt((pm.collectionVariables.get('build_poll_max') || pm.environment.get('build_poll_max')) || '20', 10);",
                  "if (state !== 'finished' && pollCount < pollMax) {",
                  "  pm.collectionVariables.set('build_poll_count', String(pollCount + 1)); try { pm.environment.set('build_poll_count', String(pollCount + 1)); } catch (e) {}",
                  "  postman.setNextRequest(pm.info.requestName);",
                  "} else {",
                  "  pm.collectionVariables.unset('build_poll_count'); try { pm.environment.unset('build_poll_count'); } catch (e) {}",
