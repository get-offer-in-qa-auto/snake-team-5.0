    {
      "name": "Chain B - Agent readiness",
      "item": [
        {
          "name": "B1 Find ready agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "const agents = Array.isArray(data.agent) ? data.agent : [];",
                  "const ready = agents.find(function (agent) { return agent.authorized === true && agent.connected === true && agent.enabled !== false; });",
                  "if (ready) { pm.collectionVariables.set('agent_id', ready.id || ready.name); try { pm.environment.set('agent_id', ready.id || ready.name); } catch (e) {} }",
                  "pm.test('ready authorized/connected agent exists', function () { pm.expect(ready, 'ready agent').to.be.an('object'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/app/rest/agents?fields=agent(id,name,authorized,connected,enabled,href)"
          }
        },
        {
          "name": "B2 Get selected agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const agent = pm.response.json();",
                  "pm.test('agent is authorized and connected', function () {",
                  "  pm.expect(agent.authorized).to.eql(true);",
                  "  pm.expect(agent.connected).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/app/rest/agents/id:{{agent_id}}?fields=id,name,authorized,connected,enabled,pool(id,name)"
          }
        }
      ]
