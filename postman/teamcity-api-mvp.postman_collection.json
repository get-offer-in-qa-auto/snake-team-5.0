{
  "info": {
    "_postman_id": "6f3c8d58-5b54-4fd0-a3ff-0e5f5f0c1e20",
    "name": "TeamCity API MVP Scenarios",
    "description": "Postman collection for MVP TeamCity REST API scenarios: readiness, agent readiness, build lifecycle, failed build, cleanup, negative auth, and optional limited-user checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{teamcity_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (!pm.request.headers.has('Content-Type') && ['POST', 'PUT', 'PATCH'].includes(pm.request.method)) {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 Setup",
      "item": [
        {
          "name": "00.1 Create bearer token from username/password",
          "auth": {
            "type": "noauth"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function getVar(key) {",
                  "  return pm.collectionVariables.get(key) || pm.environment.get(key) || '';",
                  "}",
                  "function setVar(key, value) {",
                  "  pm.collectionVariables.set(key, value);",
                  "  try { pm.environment.set(key, value); } catch (e) {}",
                  "}",
                  "const username = getVar('teamcity_username');",
                  "const password = getVar('teamcity_password');",
                  "if (!username || !password) {",
                  "  throw new Error('Fill teamcity_username and teamcity_password in Current value before creating a token.');",
                  "}",
                  "const encoded = CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(`${username}:${password}`));",
                  "pm.request.headers.upsert({ key: 'Authorization', value: `Basic ${encoded}` });",
                  "const existingName = getVar('token_name');",
                  "if (!existingName) {",
                  "  setVar('token_name', `postman-teamcity-${Date.now()}`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const token = pm.response.json();",
                  "pm.test('token value is returned once', function () { pm.expect(token.value).to.be.a('string').and.not.empty; });",
                  "if (token.value) {",
                  "  pm.collectionVariables.set('teamcity_token', token.value);",
                  "  try { pm.environment.set('teamcity_token', token.value); } catch (e) {}",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{token_name}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{base_url}}/app/rest/users/current/tokens?fields=name,value,creationTime"
          }
        },
        {
          "name": "00.2 Generate run variables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function setVar(key, value) {",
                  "  pm.collectionVariables.set(key, value);",
                  "  try { pm.environment.set(key, value); } catch (e) {}",
                  "}",
                  "const runId = Date.now().toString();",
                  "setVar('run_id', runId);",
                  "setVar('project_id', `AutotestApiProject${runId}`);",
                  "setVar('project_name', `Autotest API Project ${runId}`);",
                  "setVar('build_type_id', `AutotestApiBuild${runId}`);",
                  "setVar('build_type_name', `Autotest API Build ${runId}`);",
                  "setVar('vcs_root_id', `AutotestApiVcs${runId}`);",
                  "setVar('vcs_root_name', `Autotest API VCS ${runId}`);",
                  "setVar('vcs_root_entry_id', `AutotestApiVcsEntry${runId}`);",
                  "setVar('step_id', `AutotestApiStep${runId}`);",
                  "setVar('failing_step_id', `AutotestApiFailStep${runId}`);",
                  "setVar('limited_username', `autotest_limited_${runId}`);",
                  "setVar('limited_password', `Autotest-${runId}!`);",
                  "setVar('limited_role_scope', `p:${pm.collectionVariables.get('project_id') || pm.environment.get('project_id')}`);",
                  "pm.collectionVariables.unset('build_id');",
                  "pm.collectionVariables.unset('failed_build_id');",
                  "pm.collectionVariables.unset('queued_build_locator');",
                  "pm.collectionVariables.unset('build_poll_count');",
                  "pm.collectionVariables.unset('failed_build_poll_count');",
                  "try { pm.environment.unset('build_id'); pm.environment.unset('failed_build_id'); pm.environment.unset('queued_build_locator'); pm.environment.unset('build_poll_count'); pm.environment.unset('failed_build_poll_count'); } catch (e) {}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('run variables generated', function () {",
                  "  const projectId = pm.collectionVariables.get('project_id') || pm.environment.get('project_id');",
                  "  const buildTypeId = pm.collectionVariables.get('build_type_id') || pm.environment.get('build_type_id');",
                  "  pm.expect(projectId).to.match(/^AutotestApiProject/);",
                  "  pm.expect(buildTypeId).to.match(/^AutotestApiBuild/);",
                  "});",
                  "pm.test('server reachable with bearer token', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/app/rest/server?fields=version,buildNumber"
          }
        }
      ]
    },
